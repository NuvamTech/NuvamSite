    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "vite": "^7.1.2"
  }
